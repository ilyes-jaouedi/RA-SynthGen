# Copy this file to .env and fill in your paths.
#
# Linux / macOS:   source .env
# Windows (PS):    Get-Content .env | ForEach-Object { $k,$v=$_.Split('=',2); [System.Environment]::SetEnvironmentVariable($k,$v) }

# Path to EchoFusion labels directory.
# Contains one {frame_id:06d}.txt file per annotated frame.
# Format per line:  x  y  z  dim_x  dim_y  dim_z  theta  [class]
LABELS_DIR=/path/to/EchoFusion_data/labels_x
